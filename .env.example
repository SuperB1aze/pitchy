# =============================================================================
# Pitchy — пример переменных окружения.
# Скопируйте файл в .env и при необходимости замените значения:
#   cp .env.example .env
# Значения ниже — моковые и подходят для локальной разработки "из коробки"
# (см. README.md -> "Локальный запуск").
# =============================================================================

# --- PostgreSQL: подключение приложения ------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pitchy
DB_USER=pitchy_user
DB_PASS=pitchy_password

# Пользователь, от имени которого поднимается контейнер Postgres и
# накатываются миграции Alembic. Для локальной разработки можно оставить
# таким же, как DB_USER/DB_PASS выше.
DB_MIGRATION_USER=pitchy_user
DB_MIGRATION_PASS=pitchy_password

# --- Тестовая БД (зарезервировано под тесты, пока не используется кодом) ---
TEST_MODE=false
DB_TEST_HOST=localhost
DB_TEST_PORT=5433
DB_TEST_USER=pitchy_test_user
DB_TEST_PASS=pitchy_test_password
DB_TEST_NAME=pitchy_test

# --- JWT (RS256) -------------------------------------------------------------
# Пароль (passphrase) для приватного RSA-ключа certs/private.pem.
# Оставьте пустым, если ключ сгенерирован без пароля (см. README.md).
PASSPHRASE=
# true/1 — cookie с refresh-токеном будет отправляться только по HTTPS.
# Для локальной разработки по http держите пустым/false.
REFRESH_COOKIE_SECURE=false

# --- MinIO (S3-совместимое хранилище медиафайлов анкет) ---------------------
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=minio_password
S3_BUCKET=pitchy-media
S3_REGION=us-east-1
S3_SECURE=false

# --- Внешние сервисы проверки контрагентов -----------------------------------
# DaData (проверка ЕГРЮЛ/ЕГРИП по ИНН): https://dadata.ru/api/find-party/
DADATA_API_KEY=your_dadata_api_key
# DaMIA (проверка ФССП/исполнительных производств): https://damia.ru/api-fssp
DAMIA_API_KEY=your_damia_api_key
